# Copy to ops/ga4/.env (gitignored) or export in shell.
# Property ID = digits only (Admin → Property settings), NOT G-XXXXXXXX.
GA4_PROPERTY_ID=000000000

# Path to service account JSON (relative to repo root or absolute)
GOOGLE_APPLICATION_CREDENTIALS=ops/ga4/service-account.json

# Optional: Measurement Protocol (Django prod uses its own .env)
# GA4_MEASUREMENT_ID=G-XXXXXXXX
# GA4_API_SECRET=