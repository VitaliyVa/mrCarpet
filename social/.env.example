# Copy these into project .env (never commit secrets)

# Meta Graph (Instagram Reels + Facebook Page)
# META_PAGE_ACCESS_TOKEN=
# META_PAGE_ID=
# META_IG_USER_ID=
# META_GRAPH_VERSION=v21.0

# TikTok Content Posting API
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_OPEN_ID=
# TIKTOK_AUDIT_PASSED=false

# Optional override for Wan I2V model
# SOCIAL_AI_I2V_MODEL=wan-video/wan-2.2-i2v-fast
