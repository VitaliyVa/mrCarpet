server{
    server_name mrcarpet24.com;
    client_max_body_size 100M;

    gzip on;
    gzip_comp_level 5;
    gzip_min_length 256;
    gzip_proxied any;
    gzip_vary on;
    gzip_types
        text/plain
        text/css
        text/javascript
        application/javascript
        application/json
        application/xml
        image/svg+xml
        font/ttf
        font/otf
        application/font-woff
        application/font-woff2;
    
    location = /favicon.ico { 
        access_log off; 
        log_not_found off; 
    }
    
    location /media {
        alias /home/carpet/projects/carpet/src/media;
        expires 30d;
        add_header Cache-Control "public";
    }
    
    location /static {
        alias /home/carpet/projects/carpet/src/static_root;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
    
    location / {
        uwsgi_pass unix:/home/carpet/projects/carpet/src/config/mrcarpet.sock;
        include /etc/nginx/uwsgi_params;
        uwsgi_read_timeout 300;
        uwsgi_send_timeout 300;
    }



    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/mrcarpet24.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/mrcarpet24.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server{
    if ($host = mrcarpet24.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    server_name mrcarpet24.com;
    listen 80;
    return 404; # managed by Certbot


}

